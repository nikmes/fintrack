# Copy this file to .env and adjust as needed.
# docker compose loads .env automatically; every value below has a sensible
# default baked into docker-compose.yml, so .env is optional for local dev.

# --- PostgreSQL ---
POSTGRES_USER=fintrack_user
POSTGRES_PASSWORD=fintrack_password
POSTGRES_DB=fintrack

# --- Backend (ASP.NET Core) ---
# Development enables Swagger and auto-applies EF Core migrations on startup.
ASPNETCORE_ENVIRONMENT=Development

# The backend connection string is assembled in docker-compose.yml from the
# POSTGRES_* values above and injected as ConnectionStrings__DefaultConnection.
# Inside the compose network the DB host is "postgres" (the service name):
#   Host=postgres;Port=5432;Database=fintrack;Username=fintrack_user;Password=fintrack_password
